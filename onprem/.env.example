# ── Vaultak On-Premises Configuration ─────────────────────────────────────────
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_this_secure_password
ADMIN_KEY=change_this_admin_key

# ── Ports ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
DASHBOARD_PORT=3000

# ── Auth ──────────────────────────────────────────────────────────────────────
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_key_here
REACT_APP_API_URL=http://localhost:8000

# ── SIEM Integrations (all optional) ──────────────────────────────────────────
# VAULTAK_SPLUNK_URL=https://your-splunk.company.com:8088
# VAULTAK_SPLUNK_TOKEN=your-hec-token
# VAULTAK_DATADOG_API_KEY=your-datadog-api-key
# VAULTAK_SENTINEL_WORKSPACE_ID=your-workspace-id
# VAULTAK_SENTINEL_SHARED_KEY=your-shared-key
# VAULTAK_ELASTIC_URL=https://your-elastic.company.com:9200
# VAULTAK_WEBHOOK_URL=https://your-siem.company.com/webhook
# VAULTAK_SLACK_WEBHOOK=https://hooks.slack.com/services/your/webhook/url
# VAULTAK_PAGERDUTY_KEY=your-integration-key

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=vaultak
POSTGRES_USER=vaultak
ENVIRONMENT=production
